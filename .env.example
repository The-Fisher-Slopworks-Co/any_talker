# Required
BOT_TOKEN=
OPENROUTER_API_KEY=
BOT_OWNER_ID=
WEBAPP_URL=https://example.com/webapp

# Optional
WEBHOOK_URL=
KEYDB_URL=redis://localhost:6379
PORT=8080

# Logging
# LOG_FORMAT: "json" | "pretty". Defaults to "json" when NODE_ENV=production, "pretty" otherwise.
LOG_FORMAT=
# LOG_INCOMING_UPDATES: log metadata for every incoming Telegram update. Default: true.
LOG_INCOMING_UPDATES=true
