# Required
BOT_TOKEN=
OPENROUTER_API_KEY=
BOT_OWNER_ID=

# Optional
KEYDB_URL=redis://localhost:6379
PORT=8080

# Production Compose (docker-compose.prod.yml) only
# DOMAIN is the public hostname Caddy serves on.
DOMAIN=
LETSENCRYPT_EMAIL=
# Observability retention (passed to VictoriaMetrics / VictoriaLogs).
VM_RETENTION=90d
VL_RETENTION=30d

# Logging
# LOG_FORMAT: "json" | "pretty". Defaults to "json" when NODE_ENV=production, "pretty" otherwise.
LOG_FORMAT=
# LOG_INCOMING_UPDATES: log metadata for every incoming Telegram update. Default: true.
LOG_INCOMING_UPDATES=true

# HTTP(S) proxy. Applies to every outbound fetch (Telegram Bot API via grammY,
# OpenRouter, fetch_page / search_web tools, Telegram file downloads).
# Handled natively by Bun: NO_PROXY is a comma-separated list of hosts to
# bypass (exact-match against the hostname; per-entry port supported as
# "host:port"; "*" disables the proxy entirely). Lowercase variants
# (http_proxy, https_proxy, no_proxy) are also recognised.
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=
