# Minimal production Caddyfile for any_talker.
# Copy to ./Caddyfile (no extension change) and use as-is in 99% of cases.
# Caddy auto-issues and renews Let's Encrypt certs for {$DOMAIN}.

{
	email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Keep internal observability endpoints private. The bot stays on the
	# internal Docker network, but if any HTTP path reaches Caddy we still
	# want to refuse access to operational data.
	@internal path /metrics /metrics/*
	respond @internal 404

	# Everything else (webapp + api) goes to the bot.
	reverse_proxy bot:8080
}
